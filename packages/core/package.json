{
  "name": "@ai-hooks/core",
  "version": "1.0.0-alpha.34",
  "description": "Framework-agnostic AI UI utilities for AI Hooks.",
  "license": "MIT",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/ai-hooks"
  },
  "type": "module",
  "homepage": "https://ai-hooks.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DumanTorbayev/ai-hooks.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/DumanTorbayev/ai-hooks/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "tokens",
    "streaming",
    "model-cost",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cost": {
      "types": "./dist/cost.d.ts",
      "import": "./dist/cost.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
      "import": "./dist/streaming.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
