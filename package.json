{
  "name": "ai-hooks-project",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @ai-hooks/web dev",
    "build": "pnpm --filter @ai-hooks/core build && pnpm --filter @ai-hooks/react build && pnpm --filter @ai-hooks/web build",
    "test": "pnpm --filter @ai-hooks/core test && pnpm --filter @ai-hooks/react test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @ai-hooks/core typecheck && pnpm --filter @ai-hooks/react typecheck && pnpm --filter @ai-hooks/web typecheck",
    "lint": "pnpm -r lint && pnpm lint:eslint && pnpm format:check",
    "lint:eslint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.5.19",
    "@playwright/test": "^1.61.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.5",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
